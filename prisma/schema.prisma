generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  logoUrl   String?
  timezone  String   @default("America/Toronto")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBranches             UserBranch[]
  suppliers                Supplier[]
  ingredients              Ingredient[]
  equipment                Equipment[]
  recipeCategories         RecipeCategory[]
  recipes                  Recipe[]
  recipeIngredients        RecipeIngredient[]
  purchaseHistories        PurchaseHistory[]
  purchaseOrders           PurchaseOrder[]
  purchaseOrderItems       PurchaseOrderItem[]
  productionSchedules      ProductionSchedule[]
  prepStations             PrepStation[]
  prepTaskTemplates        PrepTaskTemplate[]
  prepBoardTasks           PrepBoardTask[]
  prepActivityLogs         PrepActivityLog[]
  prepTasks                PrepTask[]
  batchPlans               BatchPlan[]
  batchPlanItems           BatchPlanItem[]
  salesEntries             SalesEntry[]
  inventoryItems           InventoryItem[]
  inventoryTransactions    InventoryTransaction[]
  storageAreas             StorageArea[]
  storageAreaWatchers      StorageAreaWatcher[]
  notificationLogs         NotificationLog[]
  ingredientSuppliers      IngredientSupplier[]
  portionStandards         PortionStandard[]
  pmixUploads              PmixUpload[]
  pmixItems                PmixItem[]
  pmixModifiers            PmixModifier[]
  pmixItemRules            PmixItemRule[]
  ingredientCategories     IngredientCategory[]
  userCategoryPermissions  UserCategoryPermission[]
  userRecipeCategoryPermissions UserRecipeCategoryPermission[]
  auditLogs                AuditLog[]
  reportStations           ReportStation[]
  reportStationMenus       ReportStationMenu[]
  storageAreaCounts        StorageAreaCount[]
  reportUnitChains         ReportUnitChain[]
  lossUploads              LossUpload[]
  lossComplaints           LossComplaint[]
  lossDiscounts            LossDiscount[]
  lossReasonMaps           LossReasonMap[]
  serverSalesUploads       ServerSalesUpload[]
  serverSalesRows          ServerSalesRow[]
  compositeRecipes         CompositeRecipe[]
  compositeComponents      CompositeComponent[]
  menuCompositeLinks       MenuCompositeLink[]
  proteinGroups            ProteinGroup[]
  proteinGroupMembers      ProteinGroupMember[]

  @@map("branches")
}

model UserBranch {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isDefault Boolean @default(false)

  @@unique([userId, branchId])
  @@index([userId])
  @@index([branchId])
  @@map("user_branches")
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String   // bcrypt hash
  role        String   @default("staff") // "admin" | "manager" | "chef" | "analyst" | "staff"
  permissions String[] // custom slug overrides; empty = use role defaults
  department  String?  // e.g. "Bar", "Kitchen", "Bakery", "Pastry"
  isActive    Boolean  @default(true)
  notificationPrefs Json? // { quietHoursStart, quietHoursEnd, channels, digestOnly }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryPermissions       UserCategoryPermission[]
  recipeCategoryPermissions UserRecipeCategoryPermission[]
  auditLogs                 AuditLog[]
  storageAreaWatchers       StorageAreaWatcher[]
  userBranches              UserBranch[]

  @@map("users")
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contact     String
  email       String
  phone       String
  address     String
  status      String    // "Active" | "Inactive"
  isSpecial   Boolean   @default(false)

  // ── Delivery schedule (drives lead-time calc for PAR Min / ROP / Max) ──
  deliveryDays         Int[]   @default([])              // ISO weekdays: 1=Mon … 7=Sun
  orderCutoffTime      String?                           // "HH:MM" 24h, time-of-day order cutoff
  orderCutoffDayOffset Int     @default(1)               // days BEFORE delivery (1 = order by cutoff the day before)
  deliveryTimeWindow   String?                           // e.g. "08:00-10:00"
  minOrderValue        Decimal? @db.Decimal(10, 2)       // optional minimum order value
  deliveryNotes        String?                           // free text (e.g. "Order via LINE")

  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ingredients         Ingredient[]
  purchaseHistory     PurchaseHistory[]
  ingredientSuppliers IngredientSupplier[]
  purchaseOrders      PurchaseOrder[]

  @@index([branchId])
  @@map("suppliers")
}

model Ingredient {
  id                     String              @id @default(cuid())
  name                   String
  sku                    String?
  supplierId             String
  supplier               Supplier            @relation(fields: [supplierId], references: [id])
  purchaseUnit           String
  purchasePrice          Decimal             @db.Decimal(10, 2)
  recipeUnit             String
  yieldPercent           Decimal             @db.Decimal(5, 2)
  conversionRate         Decimal             @db.Decimal(10, 4)
  groupId                String
  categoryId             String?
  category               IngredientCategory? @relation(fields: [categoryId], references: [id])
  storageAreaId          String?
  storageArea            StorageArea?        @relation(fields: [storageAreaId], references: [id])
  averageCostPerBaseUnit Decimal?            @db.Decimal(10, 6)
  reportUnit             String?
  imageUrl               String?

  branchId               String?
  branch                 Branch?             @relation(fields: [branchId], references: [id])

  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  recipeItems         RecipeIngredient[]
  inventoryItem       InventoryItem?
  inventoryTxns       InventoryTransaction[]
  ingredientSuppliers IngredientSupplier[]
  portionStandards    PortionStandard[]
  compositeComponents CompositeComponent[]
  proteinGroupMembers ProteinGroupMember[]

  @@unique([sku, branchId])
  @@index([branchId])
  @@map("ingredients")
}

model Equipment {
  id        String   @id @default(cuid())
  name      String
  type      String
  status    String   // "Available" | "Maintenance" | "Retired"

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@map("equipment")
}

model RecipeCategory {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int      @default(0)

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPermissions UserRecipeCategoryPermission[]

  @@unique([name, branchId])
  @@index([branchId])
  @@map("recipe_categories")
}

model UserRecipeCategoryPermission {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   RecipeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignedAt DateTime       @default(now())

  branchId   String?
  branch     Branch?        @relation(fields: [branchId], references: [id])

  @@unique([userId, categoryId])
  @@index([branchId])
  @@map("user_recipe_category_permissions")
}

model Recipe {
  id                 String    @id @default(cuid())
  name               String
  category           String
  yieldAmount        Decimal   @db.Decimal(10, 2)
  yieldUnit          String
  prepTime           Int
  cookTime           Int
  laborCostPerHour   Decimal   @db.Decimal(10, 2)
  energyCostPerBatch Decimal   @db.Decimal(10, 2)
  sellingPrice       Decimal?  @db.Decimal(10, 2)
  deliveryPrice      Decimal?  @db.Decimal(10, 2)
  imageUrl           String?
  isMainSauce        Boolean   @default(false)
  isSubRecipe        Boolean   @default(false)
  linkedIngredientId String?
  instructions       String?

  branchId           String?
  branch             Branch?   @relation(fields: [branchId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  ingredients  RecipeIngredient[]
  salesEntries SalesEntry[]

  @@index([branchId])
  @@map("recipes")
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(10, 4)

  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])

  @@unique([recipeId, ingredientId])
  @@index([branchId])
  @@map("recipe_ingredients")
}

model PurchaseHistory {
  id         String   @id @default(cuid())
  date       DateTime
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  ingredient String
  qty        Decimal  @db.Decimal(10, 2)
  unit       String
  unitPrice  Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)

  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([branchId])
  @@map("purchase_history")
}

// ─── Purchase Orders (DB-backed; replaces the old localStorage version) ──────
model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String                               // "PO-2026-0001"
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  supplierName String                               // snapshot at creation
  status       String              @default("Draft") // Draft | Sent | Received | Cancelled
  orderDate    String                               // YYYY-MM-DD
  deliveryDate String?                              // YYYY-MM-DD (expected)
  notes        String?
  grandTotal   Decimal             @db.Decimal(12, 2) @default(0)
  createdById  String?                              // user who created it
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  branchId     String?
  branch       Branch?             @relation(fields: [branchId], references: [id])

  items PurchaseOrderItem[]

  @@unique([poNumber, branchId])
  @@index([status])
  @@index([supplierId])
  @@index([branchId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String?                            // optional link to Ingredient
  ingredientName  String                             // snapshot / free text
  qty             Decimal       @db.Decimal(10, 4)    // ordered qty (purchase unit)
  unit            String
  unitPrice       Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(12, 2)
  receivedQty     Decimal?      @db.Decimal(10, 4)    // actual qty received (null = not yet received)

  branchId        String?
  branch          Branch?       @relation(fields: [branchId], references: [id])

  @@index([purchaseOrderId])
  @@index([branchId])
  @@map("purchase_order_items")
}

model ProductionSchedule {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  items     String[] // task descriptions
  status    String   @default("pending") // "pending" | "completed"

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
  @@map("production_schedules")
}

// ─── Master Prep List (persistent daily prep tasks per station) ──────────────
model PrepStation {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("utensils")
  color     String   @default("bg-slate-500")
  sortOrder Int      @default(0)
  memberIds String[] @default([])

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  templates PrepTaskTemplate[]

  @@index([branchId])
  @@map("prep_stations")
}

// Master backlog of reusable prep tasks for a station (the "Task List" column).
model PrepTaskTemplate {
  id        String      @id @default(cuid())
  stationId String
  station   PrepStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  name      String
  qty       String?
  dueTime   String?
  sortOrder Int         @default(0)
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  branchId  String?
  branch    Branch?      @relation(fields: [branchId], references: [id])

  boardTasks PrepBoardTask[]

  @@index([stationId])
  @@index([branchId])
  @@map("prep_task_templates")
}

// A template placed onto a given day's board (To-Do or Complete column).
model PrepBoardTask {
  id          String           @id @default(cuid())
  date        String                            // YYYY-MM-DD
  stationId   String                            // denormalised for fast board queries
  templateId  String
  template    PrepTaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  status      String           @default("todo")  // "todo" | "complete"
  todoAt      DateTime?
  todoBy      String?
  completedAt DateTime?
  completedBy String?
  sortOrder   Int              @default(0)

  branchId    String?
  branch      Branch?          @relation(fields: [branchId], references: [id])

  @@unique([date, templateId])
  @@index([date, stationId])
  @@index([branchId])
  @@map("prep_board_tasks")
}

// Immutable activity log → powers frequency + staff-performance analytics.
// Survives the daily board reset.
model PrepActivityLog {
  id          String   @id @default(cuid())
  date        String
  stationId   String
  stationName String
  templateId  String?
  taskName    String
  action      String
  userId      String?
  userName    String?

  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  at          DateTime @default(now())

  @@index([date])
  @@index([action])
  @@index([userId])
  @@index([branchId])
  @@map("prep_activity_logs")
}

model PrepTask {
  id        String    @id @default(cuid())
  date      String
  station   String
  name      String
  qty       String?
  dueTime   String?
  done      Boolean   @default(false)
  doneBy    String?
  doneAt    DateTime?
  sortOrder Int       @default(0)

  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([date])
  @@index([branchId])
  @@map("prep_tasks")
}

model BatchPlan {
  id        String          @id @default(cuid())
  date      String
  status    String          @default("Pending")
  progress  Int             @default(0)

  branchId  String?
  branch    Branch?         @relation(fields: [branchId], references: [id])

  items     BatchPlanItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([branchId])
  @@map("batch_plans")
}

model BatchPlanItem {
  id          String    @id @default(cuid())
  batchPlanId String
  batchPlan   BatchPlan @relation(fields: [batchPlanId], references: [id], onDelete: Cascade)
  recipeId    String?
  recipeName  String
  qty         String
  unit        String

  branchId    String?
  branch      Branch?   @relation(fields: [branchId], references: [id])

  @@index([branchId])
  @@map("batch_plan_items")
}

model SalesEntry {
  id         String   @id @default(cuid())
  date       String
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  recipeName String
  qty        Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  revenue    Decimal  @db.Decimal(10, 2)
  unitCost   Decimal? @db.Decimal(10, 2)
  notes      String?

  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
  @@index([branchId])
  @@map("sales_entries")
}

model InventoryItem {
  id            String    @id @default(cuid())
  ingredientId  String    @unique
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  currentStock  Decimal   @db.Decimal(10, 4)
  parMin        Decimal   @db.Decimal(10, 4)
  parMax        Decimal   @db.Decimal(10, 4)
  reorderPoint  Decimal   @db.Decimal(10, 4)
  leadTimeDays  Int       @default(1)
  holdingDays   Int       @default(7)
  packUnit      String?
  packSize      Decimal?  @db.Decimal(10, 4)
  lastCountDate DateTime?

  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions InventoryTransaction[]

  @@index([branchId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])
  type            String        // "In" | "Out" | "Waste" | "Adjust" | "Stocktake"
  qty             Decimal       @db.Decimal(10, 4)  // always positive; direction implied by type
  unit            String        // recipe unit (g, ml, piece)
  costPerUnit     Decimal?      @db.Decimal(10, 6)  // for In transactions
  reason          String?       // for Waste: "Spoiled" | "Overcooked" | "Staff" | "Other"
  note            String?
  date            String        // YYYY-MM-DD
  recipeId        String?       // for Out: sale that triggered this
  varianceQty     Decimal?      @db.Decimal(10, 4)

  branchId        String?
  branch          Branch?       @relation(fields: [branchId], references: [id])

  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([date])
  @@index([branchId])
  @@map("inventory_transactions")
}

// ─── V3: SKU, Storage Areas, Multi-Supplier & MAC Engine ─────────────────────

model StorageArea {
  id          String       @id @default(cuid())
  name        String
  temperature String?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)

  notifyEnabled   Boolean  @default(true)
  alertThreshold  String   @default("reorder")
  digestSchedule  String   @default("daily")
  digestHourLocal Int      @default(8)
  digestDayOfWeek Int?

  branchId    String?
  branch      Branch?      @relation(fields: [branchId], references: [id])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ingredients Ingredient[]
  watchers    StorageAreaWatcher[]

  @@unique([name, branchId])
  @@index([branchId])
  @@map("storage_areas")
}

model StorageAreaWatcher {
  id             String      @id @default(cuid())
  storageAreaId  String
  storageArea    StorageArea @relation(fields: [storageAreaId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String      @default("watcher")
  alertThreshold String?
  digestSchedule String?
  ccOnly         Boolean     @default(false)

  branchId       String?
  branch         Branch?     @relation(fields: [branchId], references: [id])

  createdAt      DateTime    @default(now())

  @@unique([storageAreaId, userId])
  @@index([userId])
  @@index([branchId])
  @@map("storage_area_watchers")
}

model NotificationLog {
  id            String   @id @default(cuid())
  type          String
  storageAreaId String?
  ingredientId  String?
  userId        String?
  email         String
  subject       String
  status        String
  errorMsg      String?
  dedupeKey     String

  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])

  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@unique([dedupeKey, branchId])
  @@index([type, createdAt])
  @@index([storageAreaId])
  @@index([userId])
  @@index([branchId])
  @@map("notification_logs")
}

model IngredientSupplier {
  id             String     @id @default(cuid())
  ingredientId   String
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplierId     String
  supplier       Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchasePrice  Decimal    @db.Decimal(10, 2)
  purchaseUnit   String
  conversionRate Decimal    @db.Decimal(10, 4)
  isPreferred    Boolean    @default(false)
  notes          String?

  branchId       String?
  branch         Branch?    @relation(fields: [branchId], references: [id])

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([ingredientId, supplierId])
  @@index([branchId])
  @@map("ingredient_suppliers")
}

// ─── Portion Standards (BOM-free portion calculator) ─────────────────────────

model PortionStandard {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  itemName     String
  type         String     @default("base")
  portionSize  Decimal    @db.Decimal(10, 4)
  portionUnit  String
  notes        String?

  branchId     String?
  branch       Branch?    @relation(fields: [branchId], references: [id])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([ingredientId])
  @@index([itemName])
  @@index([branchId])
  @@map("portion_standards")
}

// ─── PMIX: Product-Mix Upload & Analytics ────────────────────────────────────

model PmixUpload {
  id           String    @id @default(cuid())
  fileName     String
  periodLabel  String?
  businessDate DateTime? @db.Date
  totalItems   Int       @default(0)
  totalQty     Int       @default(0)
  totalSales   Decimal   @db.Decimal(12, 2) @default(0)

  branchId     String?
  branch       Branch?   @relation(fields: [branchId], references: [id])

  uploadedAt   DateTime  @default(now())

  items PmixItem[]

  @@index([businessDate])
  @@index([branchId])
  @@map("pmix_uploads")
}

model PmixItem {
  id             String       @id @default(cuid())
  uploadId       String
  upload         PmixUpload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  menu           String
  category       String
  itemCode       String?
  itemName       String
  qtySold        Int          @default(0)
  grossSales     Decimal      @db.Decimal(12, 2) @default(0)
  refundQty      Int          @default(0)
  refundAmount   Decimal      @db.Decimal(12, 2) @default(0)
  discountAmount Decimal      @db.Decimal(12, 2) @default(0)
  netSales       Decimal      @db.Decimal(12, 2) @default(0)
  pctNetCount    Decimal?     @db.Decimal(8, 4)
  pctNetSales    Decimal?     @db.Decimal(8, 4)
  recipeId       String?      // optional BOH recipe link

  branchId       String?
  branch         Branch?      @relation(fields: [branchId], references: [id])

  modifiers PmixModifier[]

  @@index([uploadId])
  @@index([branchId])
  @@map("pmix_items")
}

model PmixModifier {
  id             String   @id @default(cuid())
  itemId         String
  item           PmixItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modifierGroup  String
  modifier       String
  qtySold        Int      @default(0)
  grossSales     Decimal  @db.Decimal(12, 2) @default(0)
  refundQty      Int      @default(0)
  refundAmount   Decimal  @db.Decimal(12, 2) @default(0)
  discountAmount Decimal  @db.Decimal(12, 2) @default(0)
  netSales       Decimal  @db.Decimal(12, 2) @default(0)

  branchId       String?
  branch         Branch?  @relation(fields: [branchId], references: [id])

  @@index([itemId])
  @@index([branchId])
  @@map("pmix_modifiers")
}

// ─── PMIX Item Classification Rules ──────────────────────────────────────────

model PmixItemRule {
  id        String   @id @default(cuid())
  pattern   String
  matchType String   @default("contains")
  category  String
  label     String?
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  notes     String?

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isActive])
  @@index([branchId])
  @@map("pmix_item_rules")
}

// ─── V2: RBAC & Audit Trail ───────────────────────────────────────────────────

model IngredientCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  sortOrder   Int      @default(0)

  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients         Ingredient[]
  categoryPermissions UserCategoryPermission[]

  @@unique([name, branchId])
  @@index([branchId])
  @@map("ingredient_categories")
}

model UserCategoryPermission {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   IngredientCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  canEdit    Boolean            @default(true)
  assignedAt DateTime           @default(now())

  branchId   String?
  branch     Branch?            @relation(fields: [branchId], references: [id])

  @@unique([userId, categoryId])
  @@index([branchId])
  @@map("user_category_permissions")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName    String?
  userEmail   String?
  userRole    String?
  action      String
  targetTable String
  targetId    String
  targetName  String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?

  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([targetTable])
  @@index([createdAt])
  @@index([branchId])
  @@map("audit_logs")
}

// ─── Station Prep Report ─────────────────────────────────────────────────────
// Stations that own a set of PMIX menu items; "Run Report" explodes those menus
// into ingredient prep quantities (per weekday avg or per dated day) for planning.
model ReportStation {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("utensils")
  color     String   @default("bg-slate-500")
  sortOrder Int      @default(0)

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menus ReportStationMenu[]

  @@index([branchId])
  @@map("report_stations")
}

model ReportStationMenu {
  id        String        @id @default(cuid())
  stationId String
  station   ReportStation @relation(fields: [stationId], references: [id], onDelete: Cascade)
  itemName  String
  createdAt DateTime      @default(now())

  branchId  String?
  branch    Branch?       @relation(fields: [branchId], references: [id])

  @@unique([stationId, itemName])
  @@index([stationId])
  @@index([branchId])
  @@map("report_station_menus")
}

// ─── Physical Stock Count — per Storage Area ─────────────────────────────────
// Lets the same ingredient be counted in several storage areas; the rolled-up
// total (sum across areas) becomes the ingredient's currentStock.
model StorageAreaCount {
  id            String   @id @default(cuid())
  ingredientId  String
  storageAreaId String
  recipeQty     Decimal  @db.Decimal(12, 4)
  countedAt     DateTime @default(now())

  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])

  @@unique([ingredientId, storageAreaId])
  @@index([storageAreaId])
  @@index([branchId])
  @@map("storage_area_counts")
}

// ─── Usage Report — per-ingredient unit chain (flexible multi-level units) ───
// relations = [{ from, qty, to }] meaning "1 <from> = <qty> <to>". The solver
// reduces every unit to `base` so the report can show Order/oz/piece/box/case.
model ReportUnitChain {
  id           String   @id @default(cuid())
  reportKey    String?
  ingredientId String?
  base         String
  relations    Json

  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([reportKey, branchId])
  @@index([branchId])
  @@map("report_unit_chains")
}

// ─── Loss Management (Admin-only) ────────────────────────────────────────────
model LossUpload {
  id            String   @id @default(cuid())
  businessDate  DateTime
  complaintCount Int     @default(0)
  discountCount  Int     @default(0)
  hasComplaints Boolean  @default(false)
  hasDiscounts  Boolean  @default(false)

  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id])

  uploadedAt    DateTime @default(now())

  @@unique([businessDate, branchId])
  @@index([branchId])
  @@map("loss_uploads")
}

model LossComplaint {
  id               String   @id @default(cuid())
  businessDate     DateTime
  tableNumber      String
  zone             String                       // Bar | Lounge | Reserved | Main | VIP
  orderId          String
  userName         String
  isUnassignedUser Boolean  @default(false)
  actionType       String                       // "Complaint" | "Undo"
  grossAmount      Decimal  @db.Decimal(10, 2)
  netAmount        Decimal  @db.Decimal(10, 2)  // after Undo reconciliation
  isUndoReconciled Boolean  @default(false)
  itemDetail       String
  isGenericItem    Boolean  @default(false)
  reasonRaw        String
  reasonCategory   String
  device           String

  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])

  createdAt        DateTime @default(now())
  @@index([businessDate])
  @@index([branchId])
  @@map("loss_complaints")
}

model LossDiscount {
  id               String   @id @default(cuid())
  businessDate     DateTime
  createTime       DateTime?
  displayId        String
  discountName     String
  discountCategory String                       // "Order" | "Item" | "Promotion"
  discountAmount   Decimal  @db.Decimal(10, 2)  // positive
  itemCount        Int      @default(1)
  authorizedBy     String
  isAnonymousAuth  Boolean  @default(false)
  riskLevel        String                       // "LOW" | "MEDIUM" | "HIGH"
  isBulkDiscount   Boolean  @default(false)

  branchId         String?
  branch           Branch?  @relation(fields: [branchId], references: [id])

  createdAt        DateTime @default(now())
  @@index([businessDate])
  @@index([branchId])
  @@map("loss_discounts")
}

model LossReasonMap {
  id        String   @id @default(cuid())
  keyword   String
  category  String
  sortOrder Int      @default(0)

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())

  @@index([branchId])
  @@map("loss_reason_map")
}

// ─── Server Performance (Admin-only) ─────────────────────────────────────────
model ServerSalesUpload {
  id           String   @id @default(cuid())
  businessDate DateTime
  serverCount  Int      @default(0)

  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])

  uploadedAt   DateTime @default(now())

  @@unique([businessDate, branchId])
  @@index([branchId])
  @@map("server_sales_uploads")
}

model ServerSalesRow {
  id            String    @id @default(cuid())
  businessDate  DateTime
  staffName     String
  shiftStart    DateTime?
  shiftEnd      DateTime?
  shiftHours    Float     @default(0)
  grossSales    Decimal   @db.Decimal(10, 2) @default(0)
  discount      Decimal   @db.Decimal(10, 2) @default(0)
  netSales      Decimal   @db.Decimal(10, 2) @default(0)
  chargeTips    Decimal   @db.Decimal(10, 2) @default(0)
  gratuity      Decimal   @db.Decimal(10, 2) @default(0)
  serviceFees   Decimal   @db.Decimal(10, 2) @default(0)
  avgPerGuest   Decimal   @db.Decimal(10, 2) @default(0)
  avgPerOrder   Decimal   @db.Decimal(10, 2) @default(0)
  guests        Int       @default(0)
  orders        Int       @default(0)
  foodSales     Decimal   @db.Decimal(10, 2) @default(0)
  foodCount     Int       @default(0)
  beverageSales Decimal   @db.Decimal(10, 2) @default(0)
  beverageCount Int       @default(0)
  alcoholSales  Decimal   @db.Decimal(10, 2) @default(0)
  alcoholCount  Int       @default(0)
  dessertSales  Decimal   @db.Decimal(10, 2) @default(0)
  dessertCount  Int       @default(0)
  otherSales    Decimal   @db.Decimal(10, 2) @default(0)

  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id])

  createdAt     DateTime  @default(now())
  @@index([businessDate])
  @@index([branchId])
  @@map("server_sales_rows")
}

// ─── Usage Report: Composite sub-recipes (reusable) ──────────────────────────
// A composite is a named sub-recipe (e.g. "Curry Sauce") that yields `yieldQty
// yieldUnit` and is made of several real ingredients. Menu items reference a
// composite via MenuCompositeLink with a used quantity; at report time the
// composite expands and scales by (usedQty / yieldQty).
//   "Curry Sauce" yields 14 oz = Panang 7 oz + Massaman 7 oz
//   Islamic Noodles uses 14 oz Curry Sauce → 1 batch → Panang 7 + Massaman 7
model CompositeRecipe {
  id         String               @id @default(cuid())
  name       String
  yieldQty   Decimal              @db.Decimal(10, 4)
  yieldUnit  String
  notes      String?

  branchId   String?
  branch     Branch?              @relation(fields: [branchId], references: [id])

  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  components CompositeComponent[]
  menuLinks  MenuCompositeLink[]

  @@unique([name, branchId])
  @@index([branchId])
  @@map("composite_recipes")
}

model CompositeComponent {
  id           String          @id @default(cuid())
  compositeId  String
  composite    CompositeRecipe @relation(fields: [compositeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient      @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  qty          Decimal         @db.Decimal(10, 4) // amount of this ingredient per 1 batch (yieldQty)
  unit         String

  branchId     String?
  branch       Branch?         @relation(fields: [branchId], references: [id])

  @@index([compositeId])
  @@index([ingredientId])
  @@index([branchId])
  @@map("composite_components")
}

// Links a POS menu item (by name) to a composite it consumes. Kept separate from
// portion_standards (which holds the menu's raw-ingredient components) so the
// existing portion-standard flow is untouched; a dish's full recipe is its
// portion_standards rows PLUS its menu_composite_links.
model MenuCompositeLink {
  id          String          @id @default(cuid())
  itemName    String          // POS menu item name (matched case-insensitively)
  compositeId String
  composite   CompositeRecipe @relation(fields: [compositeId], references: [id], onDelete: Cascade)
  qty         Decimal         @db.Decimal(10, 4) // amount of composite used per 1 order
  unit        String          // should match the composite's yieldUnit
  notes       String?

  branchId    String?
  branch      Branch?         @relation(fields: [branchId], references: [id])

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([itemName])
  @@index([compositeId])
  @@index([branchId])
  @@map("menu_composite_links")
}

// Protein display groups for the Usage Report's Main Protein tab. A group is a
// named protein (e.g. "Chicken", "CM Wings") whose usage = the sum of its member
// ingredients across every dish/modifier/composite (same figures as the
// Ingredients tab, just consolidated under one display name and order).
model ProteinGroup {
  id        String               @id @default(cuid())
  name      String
  sortOrder Int                  @default(0)

  branchId  String?
  branch    Branch?              @relation(fields: [branchId], references: [id])

  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  members   ProteinGroupMember[]

  @@unique([name, branchId])
  @@index([branchId])
  @@map("protein_groups")
}

model ProteinGroupMember {
  id           String       @id @default(cuid())
  groupId      String
  group        ProteinGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  branchId     String?
  branch       Branch?      @relation(fields: [branchId], references: [id])

  @@unique([groupId, ingredientId])
  @@index([groupId])
  @@index([ingredientId])
  @@index([branchId])
  @@map("protein_group_members")
}
