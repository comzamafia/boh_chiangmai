generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String   // bcrypt hash
  role        String   @default("staff") // "admin" | "manager" | "chef" | "analyst" | "staff"
  permissions String[] // custom slug overrides; empty = use role defaults
  department  String?  // e.g. "Bar", "Kitchen", "Bakery", "Pastry"
  isActive    Boolean  @default(true)
  notificationPrefs Json? // { quietHoursStart, quietHoursEnd, channels, digestOnly }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryPermissions       UserCategoryPermission[]
  recipeCategoryPermissions UserRecipeCategoryPermission[]
  auditLogs                 AuditLog[]
  storageAreaWatchers       StorageAreaWatcher[]

  @@map("users")
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contact     String
  email       String
  phone       String
  address     String
  status      String    // "Active" | "Inactive"
  isSpecial   Boolean   @default(false)

  // ── Delivery schedule (drives lead-time calc for PAR Min / ROP / Max) ──
  deliveryDays         Int[]   @default([])              // ISO weekdays: 1=Mon … 7=Sun
  orderCutoffTime      String?                           // "HH:MM" 24h, time-of-day order cutoff
  orderCutoffDayOffset Int     @default(1)               // days BEFORE delivery (1 = order by cutoff the day before)
  deliveryTimeWindow   String?                           // e.g. "08:00-10:00"
  minOrderValue        Decimal? @db.Decimal(10, 2)       // optional minimum order value
  deliveryNotes        String?                           // free text (e.g. "Order via LINE")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ingredients         Ingredient[]
  purchaseHistory     PurchaseHistory[]
  ingredientSuppliers IngredientSupplier[]
  purchaseOrders      PurchaseOrder[]

  @@map("suppliers")
}

model Ingredient {
  id                     String              @id @default(cuid())
  name                   String
  sku                    String?             @unique // e.g. "SEA-WGT-TGRSHR"
  supplierId             String
  supplier               Supplier            @relation(fields: [supplierId], references: [id])
  purchaseUnit           String
  purchasePrice          Decimal             @db.Decimal(10, 2)
  recipeUnit             String
  yieldPercent           Decimal             @db.Decimal(5, 2)
  conversionRate         Decimal             @db.Decimal(10, 4)
  groupId                String              // "Weight" | "Volume" | "Count" (unit measurement type)
  categoryId             String?             // FK to IngredientCategory (food category)
  category               IngredientCategory? @relation(fields: [categoryId], references: [id])
  storageAreaId          String?             // V3: physical storage location
  storageArea            StorageArea?        @relation(fields: [storageAreaId], references: [id])
  averageCostPerBaseUnit Decimal?            @db.Decimal(10, 6) // V3: MAC — THB per recipe unit
  imageUrl               String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  recipeItems         RecipeIngredient[]
  inventoryItem       InventoryItem?
  inventoryTxns       InventoryTransaction[]
  ingredientSuppliers IngredientSupplier[]
  portionStandards    PortionStandard[]

  @@map("ingredients")
}

model Equipment {
  id        String   @id @default(cuid())
  name      String
  type      String
  status    String   // "Available" | "Maintenance" | "Retired"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("equipment")
}

model RecipeCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userPermissions UserRecipeCategoryPermission[]

  @@map("recipe_categories")
}

model UserRecipeCategoryPermission {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   RecipeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  assignedAt DateTime       @default(now())

  @@unique([userId, categoryId])
  @@map("user_recipe_category_permissions")
}

model Recipe {
  id                 String    @id @default(cuid())
  name               String
  category           String
  yieldAmount        Decimal   @db.Decimal(10, 2)
  yieldUnit          String
  prepTime           Int
  cookTime           Int
  laborCostPerHour   Decimal   @db.Decimal(10, 2)
  energyCostPerBatch Decimal   @db.Decimal(10, 2)
  sellingPrice       Decimal?  @db.Decimal(10, 2)
  deliveryPrice      Decimal?  @db.Decimal(10, 2)
  imageUrl           String?
  isMainSauce        Boolean   @default(false)
  isSubRecipe        Boolean   @default(false)
  linkedIngredientId String?   // ID of the auto-created Ingredient (set when isSubRecipe = true)
  instructions       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  ingredients  RecipeIngredient[]
  salesEntries SalesEntry[]

  @@map("recipes")
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(10, 4)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model PurchaseHistory {
  id         String   @id @default(cuid())
  date       DateTime
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  ingredient String
  qty        Decimal  @db.Decimal(10, 2)
  unit       String
  unitPrice  Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("purchase_history")
}

// ─── Purchase Orders (DB-backed; replaces the old localStorage version) ──────
model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique          // "PO-2026-0001"
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  supplierName String                               // snapshot at creation
  status       String              @default("Draft") // Draft | Sent | Received | Cancelled
  orderDate    String                               // YYYY-MM-DD
  deliveryDate String?                              // YYYY-MM-DD (expected)
  notes        String?
  grandTotal   Decimal             @db.Decimal(12, 2) @default(0)
  createdById  String?                              // user who created it
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  items PurchaseOrderItem[]

  @@index([status])
  @@index([supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  ingredientId    String?                            // optional link to Ingredient
  ingredientName  String                             // snapshot / free text
  qty             Decimal       @db.Decimal(10, 4)
  unit            String
  unitPrice       Decimal       @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(12, 2)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model ProductionSchedule {
  id        String   @id @default(cuid())
  date      String   // YYYY-MM-DD
  items     String[] // task descriptions
  status    String   @default("pending") // "pending" | "completed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("production_schedules")
}

model BatchPlan {
  id        String          @id @default(cuid())
  date      String          // YYYY-MM-DD
  status    String          @default("Pending") // "Pending" | "In Progress" | "Completed"
  progress  Int             @default(0) // 0–100
  items     BatchPlanItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("batch_plans")
}

model BatchPlanItem {
  id          String    @id @default(cuid())
  batchPlanId String
  batchPlan   BatchPlan @relation(fields: [batchPlanId], references: [id], onDelete: Cascade)
  recipeId    String?
  recipeName  String
  qty         String
  unit        String

  @@map("batch_plan_items")
}

model SalesEntry {
  id         String   @id @default(cuid())
  date       String   // YYYY-MM-DD
  recipeId   String?
  recipe     Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  recipeName String
  qty        Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  revenue    Decimal  @db.Decimal(10, 2)
  unitCost   Decimal? @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
  @@map("sales_entries")
}

model InventoryItem {
  id            String    @id @default(cuid())
  ingredientId  String    @unique
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  currentStock  Decimal   @db.Decimal(10, 4)  // in recipe units (g, ml, piece)
  parMin        Decimal   @db.Decimal(10, 4)  // safety stock level
  parMax        Decimal   @db.Decimal(10, 4)  // max stock level
  reorderPoint  Decimal   @db.Decimal(10, 4)
  leadTimeDays  Int       @default(1)
  holdingDays   Int       @default(7)          // CR: days of stock to hold (used for PAR Max calculation)
  // ── Pack / case counting layer (Physical Stock Count) ──
  // 1 pack = packSize purchaseUnits = packSize × ingredient.conversionRate recipeUnits.
  packUnit      String?                        // label e.g. "Case", "ลัง", "Bag", "Box"
  packSize      Decimal?  @db.Decimal(10, 4)   // how many purchaseUnits in one pack (e.g. 50 = 1 case of 50 lb)
  lastCountDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  transactions InventoryTransaction[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  ingredientId    String
  ingredient      Ingredient    @relation(fields: [ingredientId], references: [id])
  type            String        // "In" | "Out" | "Waste" | "Adjust" | "Stocktake"
  qty             Decimal       @db.Decimal(10, 4)  // always positive; direction implied by type
  unit            String        // recipe unit (g, ml, piece)
  costPerUnit     Decimal?      @db.Decimal(10, 6)  // for In transactions
  reason          String?       // for Waste: "Spoiled" | "Overcooked" | "Staff" | "Other"
  note            String?
  date            String        // YYYY-MM-DD
  recipeId        String?       // for Out: sale that triggered this
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
  @@index([type])
  @@index([date])
  @@map("inventory_transactions")
}

// ─── V3: SKU, Storage Areas, Multi-Supplier & MAC Engine ─────────────────────

model StorageArea {
  id          String       @id @default(cuid())
  name        String       @unique // "Dry Store", "Walk-in Fridge", "Bar Cabinet"
  temperature String?      // "Ambient" | "Chilled (2-5°C)" | "Frozen (-18°C)"
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)

  // ── Notification routing ──
  notifyEnabled   Boolean  @default(true)
  alertThreshold  String   @default("reorder") // "critical" | "reorder" | "any"
  digestSchedule  String   @default("daily")   // "off" | "realtime" | "daily" | "weekly"
  digestHourLocal Int      @default(8)         // 0-23 in Asia/Bangkok
  digestDayOfWeek Int?     // 0-6 (Mon=1) for weekly digests

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ingredients Ingredient[]
  watchers    StorageAreaWatcher[]

  @@map("storage_areas")
}

model StorageAreaWatcher {
  id             String      @id @default(cuid())
  storageAreaId  String
  storageArea    StorageArea @relation(fields: [storageAreaId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String      @default("watcher") // "owner" | "watcher"
  alertThreshold String?     // null = inherit area
  digestSchedule String?     // null = inherit area
  ccOnly         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@unique([storageAreaId, userId])
  @@index([userId])
  @@map("storage_area_watchers")
}

model NotificationLog {
  id            String   @id @default(cuid())
  type          String   // "low_stock_digest" | "critical_stock" | "stocktake_due" | "waste_spike" | "price_alert"
  storageAreaId String?
  ingredientId  String?
  userId        String?
  email         String
  subject       String
  status        String   // "queued" | "sent" | "failed" | "skipped"
  errorMsg      String?
  dedupeKey     String   @unique
  sentAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
  @@index([storageAreaId])
  @@index([userId])
  @@map("notification_logs")
}

model IngredientSupplier {
  id             String     @id @default(cuid())
  ingredientId   String
  ingredient     Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplierId     String
  supplier       Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  purchasePrice  Decimal    @db.Decimal(10, 2) // price per purchaseUnit
  purchaseUnit   String     // "kg", "L", "pack"
  conversionRate Decimal    @db.Decimal(10, 4) // 1 purchaseUnit = N recipeUnits
  isPreferred    Boolean    @default(false)
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([ingredientId, supplierId])
  @@map("ingredient_suppliers")
}

// ─── Portion Standards (BOM-free portion calculator) ─────────────────────────

model PortionStandard {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  itemName     String     // POS menu item name (type=base) or modifier name (type=modifier)
  type         String     @default("base") // "base" | "modifier"
  portionSize  Decimal    @db.Decimal(10, 4) // amount of ingredient per serving/modifier
  portionUnit  String     // "oz", "g", "kg", "ml", "L", "piece", "portion"
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([ingredientId])
  @@index([itemName])
  @@map("portion_standards")
}

// ─── PMIX: Product-Mix Upload & Analytics ────────────────────────────────────

model PmixUpload {
  id           String    @id @default(cuid())
  fileName     String
  periodLabel  String?   // e.g. "2024-01-15" or "Week of Jan 13"
  businessDate DateTime? @db.Date  // actual date of sales (may differ from uploadedAt)
  totalItems   Int       @default(0)
  totalQty     Int       @default(0)
  totalSales   Decimal   @db.Decimal(12, 2) @default(0)
  uploadedAt   DateTime  @default(now())

  items PmixItem[]

  @@index([businessDate])
  @@map("pmix_uploads")
}

model PmixItem {
  id             String       @id @default(cuid())
  uploadId       String
  upload         PmixUpload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  menu           String
  category       String
  itemCode       String?
  itemName       String
  qtySold        Int          @default(0)
  grossSales     Decimal      @db.Decimal(12, 2) @default(0)
  refundQty      Int          @default(0)
  refundAmount   Decimal      @db.Decimal(12, 2) @default(0)
  discountAmount Decimal      @db.Decimal(12, 2) @default(0)
  netSales       Decimal      @db.Decimal(12, 2) @default(0)
  pctNetCount    Decimal?     @db.Decimal(8, 4)
  pctNetSales    Decimal?     @db.Decimal(8, 4)
  recipeId       String?      // optional BOH recipe link

  modifiers PmixModifier[]

  @@index([uploadId])
  @@map("pmix_items")
}

model PmixModifier {
  id             String   @id @default(cuid())
  itemId         String
  item           PmixItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  modifierGroup  String
  modifier       String
  qtySold        Int      @default(0)
  grossSales     Decimal  @db.Decimal(12, 2) @default(0)
  refundQty      Int      @default(0)
  refundAmount   Decimal  @db.Decimal(12, 2) @default(0)
  discountAmount Decimal  @db.Decimal(12, 2) @default(0)
  netSales       Decimal  @db.Decimal(12, 2) @default(0)

  @@index([itemId])
  @@map("pmix_modifiers")
}

// ─── PMIX Item Classification Rules ──────────────────────────────────────────

model PmixItemRule {
  id        String   @id @default(cuid())
  /// Text to match against itemName (case-insensitive)
  pattern   String
  /// "exact" | "contains" | "starts_with"
  matchType String   @default("contains")
  /// "main_protein" | "extra_protein" | "dessert" | "excluded"
  category  String
  /// Human label shown in totals (e.g. "Beef", "Soft Shell Crab"). Falls back to pattern.
  label     String?
  /// Higher = checked first. Exclusion rules default 100, dessert 50, proteins 0.
  priority  Int      @default(0)
  isActive  Boolean  @default(true)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, isActive])
  @@map("pmix_item_rules")
}

// ─── V2: RBAC & Audit Trail ───────────────────────────────────────────────────

model IngredientCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ingredients         Ingredient[]
  categoryPermissions UserCategoryPermission[]

  @@map("ingredient_categories")
}

model UserCategoryPermission {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   IngredientCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  canEdit    Boolean            @default(true)
  assignedAt DateTime           @default(now())

  @@unique([userId, categoryId])
  @@map("user_category_permissions")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName    String?  // denormalized — kept even if user is deleted
  userEmail   String?
  userRole    String?
  action      String   // "CREATE" | "UPDATE" | "DELETE" | "WASTE_LOG" | "RECEIVE" | "LOGIN"
  targetTable String   // "Ingredient" | "Recipe" | "InventoryItem" | "WasteLog" etc.
  targetId    String
  targetName  String?  // human-readable name of the affected record
  oldValues   Json?    // snapshot before change
  newValues   Json?    // snapshot after change
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([targetTable])
  @@index([createdAt])
  @@map("audit_logs")
}
