{
  "buildCommand": "prisma generate && (prisma migrate deploy || (sleep 10 && prisma migrate deploy) || (sleep 20 && prisma migrate deploy)) && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cron/inventory-digest-daily",  "schedule": "0 11 * * *" },
    { "path": "/api/cron/inventory-digest-weekly", "schedule": "0 11 * * 1" },
    { "path": "/api/cron/order-reminders",         "schedule": "0 10 * * *" },
    { "path": "/api/cron/prep-reset",              "schedule": "0 19 * * *" }
  ]
}
